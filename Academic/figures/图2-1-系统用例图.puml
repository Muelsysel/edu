@startuml 图2-1 系统用例图
skinparam backgroundColor #FFFFFF
skinparam defaultFontColor #000000
skinparam actorStyle awesome
left to right direction

actor "教师" as Teacher
actor "审核员" as Auditor
actor "管理员" as Admin

rectangle "教学成果管理系统" {
  Teacher --> (登录/注册)
  Teacher --> (成果申报)
  Teacher --> (查看我的成果)
  Teacher --> (编辑草稿)
  Teacher --> (提交审核)
  Teacher --> (撤回审核)
  Teacher --> (重新提交)
  Teacher --> (上传附件)
  
  Auditor --> (登录)
  Auditor --> (查看待审成果)
  Auditor --> (审核通过)
  Auditor --> (审核驳回)
  Auditor --> (填写审核意见)
  Auditor --> (查看审核历史)
  
  Admin --> (登录)
  Admin --> (成果管理)
  Admin --> (用户管理)
  Admin --> (角色管理)
  Admin --> (菜单管理)
  Admin --> (部门管理)
  Admin --> (字典管理)
  Admin --> (新闻发布)
  Admin --> (数据统计)
  Admin --> (Excel导出)
  Admin --> (操作日志查看)
}

(查看我的成果) ..> (提交审核) : <<include>>
(编辑草稿) ..> (提交审核) : <<include>>
(审核驳回) ..> (重新提交) : <<extend>>
(查看待审成果) ..> (审核通过) : <<include>>
(查看待审成果) ..> (审核驳回) : <<include>>
(成果管理) ..> (数据统计) : <<include>>
@enduml
