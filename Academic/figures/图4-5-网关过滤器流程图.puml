@startuml 图4-5 网关过滤器工作流程图
skinparam backgroundColor #FFFFFF
skinparam defaultFontColor #000000

start

:接收HTTP请求;

if (URL以/achievement/portal/news开头?) then (是)
  :直接放行\n(公共门户通道);
  stop
endif

if (URL在IgnoreWhiteProperties\n白名单中?) then (是)
  :直接放行\n(登录/验证码/注册);
  stop
endif

:从请求头提取Authorization字段;

if (Authorization字段为空?) then (是)
  :返回401\nToken不能为空;
  stop
endif

:移除"Bearer "前缀\n获取JWT字符串;

:JwtUtils.parseToken(token)\n解析JWT获取Claims;

if (Claims为null?) then (是)
  :返回401\n令牌无效或已过期;
  stop
endif

:获取user_key = JwtUtils.getUserKey(claims);

:redisService.hasKey(\nlogin_tokens:{user_key});

if (Redis中不存在?) then (是)
  :返回401\n登录状态已过期;
  stop
endif

:获取userId和username;

if (userId或username为空?) then (是)
  :返回401\n令牌验证失败;
  stop
endif

:向请求头添加Header:\n- user_key\n- user_id\n- username;

:删除from-source Header\n(防止外部伪装内部调用);

:转发请求到下游服务;

stop

@enduml
