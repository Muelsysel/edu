<?xml version="1.0" encoding="UTF-8" ?>
<!DOCTYPE mapper
PUBLIC "-//mybatis.org//DTD Mapper 3.0//EN"
"http://mybatis.org/dtd/mybatis-3-mapper.dtd">
<mapper namespace="com.edu.achievement.mapper.EduAchievementMapper">
    
    <resultMap type="EduAchievement" id="EduAchievementResult">
        <result property="achievementId"    column="achievement_id"    />
        <result property="title"    column="title"    />
        <result property="content"    column="content"    />
        <result property="fileUrl"    column="file_url"    />
        <result property="teacherId"    column="teacher_id"    />
        <result property="collegeId"    column="college_id"    />
        <result property="status"    column="status"    />
        <result property="createBy"    column="create_by"    />
        <result property="createTime"    column="create_time"    />
        <result property="updateBy"    column="update_by"    />
        <result property="updateTime"    column="update_time"    />
        <result property="delFlag"    column="del_flag"    />
        <result property="category"    column="category"    />
        <result property="teacherName"  column="nick_name"    />
    </resultMap>

    <sql id="selectEduAchievementVo">
        select a.achievement_id, a.title, a.content, a.file_url, a.teacher_id, a.college_id,
               a.status, a.create_by, a.create_time, a.update_by, a.update_time, a.del_flag, a.category,
               u.nick_name
        from edu_achievement a
        left join sys_user u on a.teacher_id = u.user_id
    </sql>

    <select id="selectEduAchievementList" parameterType="EduAchievement" resultMap="EduAchievementResult">
        <include refid="selectEduAchievementVo"/>
        <where>  
            <if test="title != null  and title != ''"> and a.title like concat('%', #{title}, '%')</if>
            <if test="teacherId != null "> and a.teacher_id = #{teacherId}</if>
            <if test="teacherName != null and teacherName != ''"> and u.nick_name like concat('%', #{teacherName}, '%')</if>
            <if test="collegeId != null "> and a.college_id = #{collegeId}</if>
            <if test="status != null  and status != ''"> and a.status = #{status}</if>
            <if test="category != null  and category != ''"> and a.category = #{category}</if>
        </where>
    </select>
    
    <select id="selectEduAchievementByAchievementId" parameterType="Long" resultMap="EduAchievementResult">
        <include refid="selectEduAchievementVo"/>
        where a.achievement_id = #{achievementId}
    </select>

    <insert id="insertEduAchievement" parameterType="EduAchievement" useGeneratedKeys="true" keyProperty="achievementId">
        insert into edu_achievement
        <trim prefix="(" suffix=")" suffixOverrides=",">
            <if test="title != null and title != ''">title,</if>
            <if test="content != null and content != ''">content,</if>
            <if test="fileUrl != null">file_url,</if>
            <if test="teacherId != null">teacher_id,</if>
            <if test="collegeId != null">college_id,</if>
            <if test="status != null">status,</if>
            <if test="createBy != null">create_by,</if>
            <if test="createTime != null">create_time,</if>
            <if test="updateBy != null">update_by,</if>
            <if test="updateTime != null">update_time,</if>
            <if test="delFlag != null">del_flag,</if>
            <if test="category != null">category,</if>
         </trim>
        <trim prefix="values (" suffix=")" suffixOverrides=",">
            <if test="title != null and title != ''">#{title},</if>
            <if test="content != null and content != ''">#{content},</if>
            <if test="fileUrl != null">#{fileUrl},</if>
            <if test="teacherId != null">#{teacherId},</if>
            <if test="collegeId != null">#{collegeId},</if>
            <if test="status != null">#{status},</if>
            <if test="createBy != null">#{createBy},</if>
            <if test="createTime != null">#{createTime},</if>
            <if test="updateBy != null">#{updateBy},</if>
            <if test="updateTime != null">#{updateTime},</if>
            <if test="delFlag != null">#{delFlag},</if>
            <if test="category != null">#{category},</if>
         </trim>
    </insert>

    <update id="updateEduAchievement" parameterType="EduAchievement">
        update edu_achievement
        <trim prefix="SET" suffixOverrides=",">
            <if test="title != null and title != ''">title = #{title},</if>
            <if test="content != null and content != ''">content = #{content},</if>
            <if test="fileUrl != null">file_url = #{fileUrl},</if>
            <if test="teacherId != null">teacher_id = #{teacherId},</if>
            <if test="collegeId != null">college_id = #{collegeId},</if>
            <if test="status != null">status = #{status},</if>
            <if test="createBy != null">create_by = #{createBy},</if>
            <if test="createTime != null">create_time = #{createTime},</if>
            <if test="updateBy != null">update_by = #{updateBy},</if>
            <if test="updateTime != null">update_time = #{updateTime},</if>
            <if test="delFlag != null">del_flag = #{delFlag},</if>
            <if test="category != null">category = #{category},</if>
        </trim>
        where achievement_id = #{achievementId}
    </update>

    <delete id="deleteEduAchievementByAchievementId" parameterType="Long">
        delete from edu_achievement where achievement_id = #{achievementId}
    </delete>

    <delete id="deleteEduAchievementByAchievementIds" parameterType="String">
        delete from edu_achievement where achievement_id in 
        <foreach item="achievementId" collection="array" open="(" separator="," close=")">
            #{achievementId}
        </foreach>
    </delete>
</mapper>