<?xml version="1.0" encoding="UTF-8" ?>
<!DOCTYPE mapper
PUBLIC "-//mybatis.org//DTD Mapper 3.0//EN"
"http://mybatis.org/dtd/mybatis-3-mapper.dtd">
<mapper namespace="com.edu.achievement.mapper.EduNewsMapper">

    <resultMap type="EduNews" id="EduNewsResult">
        <result property="newsId" column="news_id" />
        <result property="title" column="title" />
        <result property="summary" column="summary" />
        <result property="coverImage" column="cover_image" />
        <result property="content" column="content" />
        <result property="publishTime" column="publish_time" />
        <result property="viewCount" column="view_count" />
        <result property="publishPortal" column="publish_portal" />
        <result property="sortWeight" column="sort_weight" />
        <result property="status" column="status" />
        <result property="createBy" column="create_by" />
        <result property="createTime" column="create_time" />
        <result property="updateBy" column="update_by" />
        <result property="updateTime" column="update_time" />
        <result property="delFlag" column="del_flag" />
        <result property="noticeType" column="notice_type" />
    </resultMap>

    <sql id="selectEduNewsVo">
        select news_id, title, summary, cover_image, content, publish_time, view_count, publish_portal, sort_weight,
               status, create_by, create_time, update_by, update_time, del_flag, notice_type
        from edu_news
    </sql>

    <select id="selectEduNewsList" parameterType="EduNews" resultMap="EduNewsResult">
        <include refid="selectEduNewsVo" />
        <where>
            del_flag = '0'
            <if test="title != null and title != ''"> and title like concat('%', #{title}, '%')</if>
            <if test="keyword != null and keyword != ''">
                and (title like concat('%', #{keyword}, '%') or summary like concat('%', #{keyword}, '%'))
            </if>
            <if test="publishPortal != null and publishPortal != ''"> and publish_portal = #{publishPortal}</if>
            <if test="noticeType != null and noticeType != ''"> and notice_type = #{noticeType}</if>
            <if test="status != null and status != ''"> and status = #{status}</if>
        </where>
        order by sort_weight desc, publish_time desc, news_id desc
    </select>

    <select id="selectEduNewsByNewsId" parameterType="Long" resultMap="EduNewsResult">
        <include refid="selectEduNewsVo" />
        where news_id = #{newsId} and del_flag = '0'
    </select>

    <insert id="insertEduNews" parameterType="EduNews" useGeneratedKeys="true" keyProperty="newsId">
        insert into edu_news
        <trim prefix="(" suffix=")" suffixOverrides=",">
            <if test="title != null and title != ''">title,</if>
            <if test="summary != null and summary != ''">summary,</if>
            <if test="coverImage != null and coverImage != ''">cover_image,</if>
            <if test="content != null and content != ''">content,</if>
            <if test="publishTime != null">publish_time,</if>
            <if test="viewCount != null">view_count,</if>
            <if test="publishPortal != null and publishPortal != ''">publish_portal,</if>
            <if test="sortWeight != null">sort_weight,</if>
            <if test="status != null and status != ''">status,</if>
            <if test="createBy != null and createBy != ''">create_by,</if>
            <if test="createTime != null">create_time,</if>
            <if test="noticeType != null and noticeType != ''">notice_type,</if>
            del_flag
        </trim>
        <trim prefix="values (" suffix=")" suffixOverrides=",">
            <if test="title != null and title != ''">#{title},</if>
            <if test="summary != null and summary != ''">#{summary},</if>
            <if test="coverImage != null and coverImage != ''">#{coverImage},</if>
            <if test="content != null and content != ''">#{content},</if>
            <if test="publishTime != null">#{publishTime},</if>
            <if test="viewCount != null">#{viewCount},</if>
            <if test="publishPortal != null and publishPortal != ''">#{publishPortal},</if>
            <if test="sortWeight != null">#{sortWeight},</if>
            <if test="status != null and status != ''">#{status},</if>
            <if test="createBy != null and createBy != ''">#{createBy},</if>
            <if test="createTime != null">#{createTime},</if>
            <if test="noticeType != null and noticeType != ''">#{noticeType},</if>
            '0'
        </trim>
    </insert>

    <update id="updateEduNews" parameterType="EduNews">
        update edu_news
        <trim prefix="set" suffixOverrides=",">
            <if test="title != null and title != ''">title = #{title},</if>
            <if test="summary != null">summary = #{summary},</if>
            <if test="coverImage != null">cover_image = #{coverImage},</if>
            <if test="content != null">content = #{content},</if>
            <if test="publishTime != null">publish_time = #{publishTime},</if>
            <if test="viewCount != null">view_count = #{viewCount},</if>
            <if test="publishPortal != null and publishPortal != ''">publish_portal = #{publishPortal},</if>
            <if test="sortWeight != null">sort_weight = #{sortWeight},</if>
            <if test="status != null and status != ''">status = #{status},</if>
            <if test="noticeType != null and noticeType != ''">notice_type = #{noticeType},</if>
            <if test="updateBy != null and updateBy != ''">update_by = #{updateBy},</if>
            <if test="updateTime != null">update_time = #{updateTime},</if>
        </trim>
        where news_id = #{newsId}
    </update>

    <update id="deleteEduNewsByNewsId" parameterType="Long">
        update edu_news set del_flag = '2' where news_id = #{newsId}
    </update>

    <update id="deleteEduNewsByNewsIds" parameterType="Long">
        update edu_news set del_flag = '2' where news_id in
        <foreach item="newsId" collection="array" open="(" separator="," close=")">
            #{newsId}
        </foreach>
    </update>

    <select id="selectPortalNewsList" parameterType="EduNews" resultMap="EduNewsResult">
        <include refid="selectEduNewsVo" />
        <where>
            del_flag = '0'
            and publish_portal = '1'
            and status = '0'
            <if test="keyword != null and keyword != ''">
                and (title like concat('%', #{keyword}, '%') or summary like concat('%', #{keyword}, '%'))
            </if>
            <if test="noticeType != null and noticeType != ''">
                and notice_type = #{noticeType}
            </if>
        </where>
        order by sort_weight desc, publish_time desc, news_id desc
    </select>

    <select id="selectPortalNewsByNewsId" parameterType="Long" resultMap="EduNewsResult">
        <include refid="selectEduNewsVo" />
        where news_id = #{newsId}
          and del_flag = '0'
          and publish_portal = '1'
          and status = '0'
    </select>

    <update id="increaseViewCount" parameterType="Long">
        update edu_news
        set view_count = ifnull(view_count, 0) + 1
        where news_id = #{newsId}
    </update>
</mapper>
